[general]
status_path = "~/.local/share/vdirsyncer/status/"

[pair google_calendar]
a = "google_calendar_local"
b = "google_calendar_remote"
collections = ["from b"]
conflict_resolution = "b wins"
metadata = ["color", "displayname"]

[storage google_calendar_local]
type = "filesystem"
path = "~/.calendars/google/"
fileext = ".ics"

[storage google_calendar_remote]
type = "google_calendar"
token_file = "~/.config/vdirsyncer/google_calendar_token"
client_id.fetch = ["command", "cat", "~/.config/vdirsyncer/.client_id"]
client_secret.fetch = ["command", "cat", "~/.config/vdirsyncer/.client_secret"]
read_only = true
